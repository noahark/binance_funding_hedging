# Copy this file to `.env` for local runtime configuration.
# Keep the real `.env` out of git. The repository .gitignore already excludes it.

# Binance credentials for the read-only private account channel.
# The backend will ignore these unless BINANCE_PRIVATE_CHANNEL_ENABLED=true.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_PRIVATE_CHANNEL_ENABLED=false

# Binance private-channel runtime knobs.
BINANCE_RECV_WINDOW=10000
BINANCE_PRIVATE_CHANNEL_TTL_SECONDS=3600
BINANCE_PRIVATE_CHANNEL_FAST_TTL_SECONDS=60
BINANCE_BORROW_CHECK_MAX_CALLS=50

# App runtime.
APP_BIND_HOST=127.0.0.1
APP_BIND_PORT=8787
APP_OFFLINE=false
APP_TOP_N=20
APP_CACHE_TTL_SECONDS=60
APP_REQUEST_TIMEOUT=15

# Optional offline fixture override, normally unused.
# APP_OFFLINE_RAW_DIR=reports/api-samples/public-market-contract-v2/20260703T051738Z/raw
