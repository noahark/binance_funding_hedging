{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.ai-project-harness/schemas/runner-tool-policy.schema.json",
  "title": "Runner-generated Claude Tool Policy",
  "description": "Stage-scoped Claude Code settings generated mechanically by the deterministic runner. Tool visibility remains fixed in the registered wrapper; this artifact narrows read/write paths and denies interactive shell access.",
  "type": "object",
  "additionalProperties": false,
  "required": ["permissions"],
  "properties": {
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defaultMode", "allow", "deny"],
      "properties": {
        "defaultMode": {
          "const": "dontAsk"
        },
        "allow": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "deny": {
          "type": "array",
          "uniqueItems": true,
          "contains": {
            "const": "Bash"
          },
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
