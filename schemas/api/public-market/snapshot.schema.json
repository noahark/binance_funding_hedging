{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.binance-funding-hedging/schemas/api/public-market/snapshot.schema.json",
  "title": "Public Market Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "data_time",
    "source_sample_id",
    "summary",
    "rows",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "public-market-snapshot/v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "data_time": {
      "type": "string",
      "format": "date-time"
    },
    "source_sample_id": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_rows",
        "route_counts",
        "asset_tag_counts",
        "negative_funding_status_counts"
      ],
      "properties": {
        "total_rows": {
          "type": "integer",
          "minimum": 0
        },
        "route_counts": {
          "$ref": "#/$defs/counts"
        },
        "asset_tag_counts": {
          "$ref": "#/$defs/counts"
        },
        "negative_funding_status_counts": {
          "$ref": "#/$defs/counts"
        }
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/row"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "private_channel": {
      "type": "string",
      "enum": ["enabled", "disabled"]
    },
    "sort_basis": {
      "type": "string",
      "enum": ["net_daily_yield", "abs_daily_funding_rate"]
    },
    "private_account": {
      "$ref": "#/$defs/private_account"
    },
    "borrow_validation": {
      "$ref": "#/$defs/borrow_validation_summary"
    }
  },
  "$defs": {
    "counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "decimal_string": {
      "type": "string",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$"
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "symbol",
        "base_asset",
        "quote_asset",
        "asset_tag",
        "asset_tag_source",
        "asset_tag_confidence",
        "route_class",
        "positive_funding_enabled",
        "negative_funding_status",
        "futures",
        "spot",
        "margin_public",
        "funding_history",
        "ui_flags"
      ],
      "properties": {
        "symbol": {
          "type": "string",
          "minLength": 1
        },
        "base_asset": {
          "type": "string",
          "minLength": 1
        },
        "quote_asset": {
          "const": "USDT"
        },
        "asset_tag": {
          "enum": [
            "CRYPTO",
            "BSTOCK",
            "METAL",
            "UNKNOWN"
          ]
        },
        "asset_tag_source": {
          "type": "string",
          "minLength": 1
        },
        "asset_tag_confidence": {
          "enum": [
            "HIGH",
            "MEDIUM",
            "LOW"
          ]
        },
        "route_class": {
          "enum": [
            "MARGIN_SPOT_CANDIDATE",
            "SPOT_ONLY_CANDIDATE",
            "PERP_ONLY_EXCLUDED"
          ]
        },
        "positive_funding_enabled": {
          "type": "boolean"
        },
        "negative_funding_status": {
          "enum": [
            "PRIVATE_BORROW_VALIDATION_REQUIRED",
            "DISABLED_BSTOCK",
            "DISABLED_SPOT_ONLY",
            "DISABLED_PERP_ONLY"
          ]
        },
        "futures": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "symbol",
            "status",
            "contract_type",
            "mark_price",
            "index_price",
            "last_funding_rate",
            "next_funding_time",
            "min_notional",
            "step_size"
          ],
          "properties": {
            "symbol": {
              "type": "string"
            },
            "status": {
              "type": "string"
            },
            "contract_type": {
              "type": "string"
            },
            "mark_price": {
              "$ref": "#/$defs/decimal_string"
            },
            "index_price": {
              "$ref": "#/$defs/decimal_string"
            },
            "last_funding_rate": {
              "$ref": "#/$defs/decimal_string"
            },
            "next_funding_time": {
              "type": "integer",
              "minimum": 0
            },
            "min_notional": {
              "$ref": "#/$defs/decimal_string"
            },
            "step_size": {
              "$ref": "#/$defs/decimal_string"
            }
          }
        },
        "spot": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "symbol",
            "status",
            "exists",
            "min_notional",
            "step_size"
          ],
          "properties": {
            "symbol": {
              "type": [
                "string",
                "null"
              ]
            },
            "status": {
              "type": [
                "string",
                "null"
              ]
            },
            "exists": {
              "type": "boolean"
            },
            "match_type": {
              "type": ["string", "null"],
              "enum": ["exact_symbol", "bstock_b_suffix_alias", null]
            },
            "min_notional": {
              "anyOf": [
                {
                  "$ref": "#/$defs/decimal_string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "step_size": {
              "anyOf": [
                {
                  "$ref": "#/$defs/decimal_string"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        "margin_public": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "public_cross_margin_pair",
            "source"
          ],
          "properties": {
            "public_cross_margin_pair": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "source": {
              "type": "string"
            }
          }
        },
        "funding_history": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "funding_time",
              "funding_rate"
            ],
            "properties": {
              "funding_time": {
                "type": "integer",
                "minimum": 0
              },
              "funding_rate": {
                "$ref": "#/$defs/decimal_string"
              }
            }
          }
        },
        "ui_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "funding_interval_hours": {
          "type": "integer",
          "enum": [1, 4, 8]
        },
        "daily_funding_rate": {
          "anyOf": [
            { "$ref": "#/$defs/decimal_string" },
            { "type": "null" }
          ]
        },
        "net_daily_yield": {
          "anyOf": [
            { "$ref": "#/$defs/decimal_string" },
            { "type": "null" }
          ]
        },
        "borrow_rate_source": {
          "type": ["string", "null"],
          "enum": [
            "next_hourly",
            "rate_history",
            "cross_margin_tier",
            "vip0_reference",
            null
          ]
        },
        "borrow_validation": {
          "$ref": "#/$defs/borrow_validation"
        }
      }
    },
    "borrow_validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verified", "classic_margin", "portfolio_account", "checked_at", "error"],
      "properties": {
        "verified": { "type": "boolean" },
        "classic_margin": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pair_listed", "asset_borrowable", "daily_interest_vip0", "daily_interest_account", "source"],
          "properties": {
            "pair_listed": { "type": ["boolean", "null"] },
            "asset_borrowable": { "type": ["boolean", "null"] },
            "daily_interest_vip0": {
              "anyOf": [
                { "$ref": "#/$defs/decimal_string" },
                { "type": "null" }
              ]
            },
            "daily_interest_account": {
              "anyOf": [
                { "$ref": "#/$defs/decimal_string" },
                { "type": "null" }
              ]
            },
            "source": { "type": "string" }
          }
        },
        "portfolio_account": {
          "type": "object",
          "additionalProperties": false,
          "required": ["max_borrowable", "borrow_limit", "error_code", "max_borrowable_value_usdt", "source"],
          "properties": {
            "max_borrowable": {
              "anyOf": [
                { "$ref": "#/$defs/decimal_string" },
                { "type": "null" }
              ]
            },
            "borrow_limit": {
              "anyOf": [
                { "$ref": "#/$defs/decimal_string" },
                { "type": "null" }
              ]
            },
            "error_code": { "type": ["string", "null"] },
            "max_borrowable_value_usdt": { "type": ["string", "null"] },
            "source": { "type": "string" }
          }
        },
        "checked_at": { "type": ["string", "null"] },
        "error": { "type": ["string", "null"] }
      }
    },
    "private_account": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified",
        "balances_unified",
        "balances_spot",
        "um_positions",
        "total_value_usdt",
        "valuation",
        "checked_at",
        "error"
      ],
      "properties": {
        "verified": { "type": "boolean" },
        "balances_unified": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["asset", "total_balance"],
            "properties": {
              "asset": { "type": "string" },
              "total_balance": {
                "anyOf": [
                  { "$ref": "#/$defs/decimal_string" },
                  { "type": "null" }
                ]
              },
              "value_usdt": {
                "anyOf": [
                  { "$ref": "#/$defs/decimal_string" },
                  { "type": "null" }
                ]
              }
            }
          }
        },
        "balances_spot": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["asset", "free", "locked"],
            "properties": {
              "asset": { "type": "string" },
              "free": {
                "anyOf": [
                  { "$ref": "#/$defs/decimal_string" },
                  { "type": "null" }
                ]
              },
              "locked": {
                "anyOf": [
                  { "$ref": "#/$defs/decimal_string" },
                  { "type": "null" }
                ]
              },
              "value_usdt": {
                "anyOf": [
                  { "$ref": "#/$defs/decimal_string" },
                  { "type": "null" }
                ]
              }
            }
          }
        },
        "um_positions": {
          "type": "array",
          "items": { "$ref": "#/$defs/um_position" }
        },
        "total_value_usdt": {
          "anyOf": [
            { "$ref": "#/$defs/decimal_string" },
            { "type": "null" }
          ]
        },
        "valuation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["price_source", "priced_at"],
          "properties": {
            "price_source": { "type": "string" },
            "priced_at": { "type": ["string", "null"] }
          }
        },
        "checked_at": { "type": ["string", "null"] },
        "error": { "type": ["string", "null"] }
      }
    },
    "um_position": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "symbol",
        "position_side",
        "position_amt",
        "entry_price",
        "mark_price",
        "unrealized_profit",
        "liquidation_price"
      ],
      "properties": {
        "symbol": { "type": ["string", "null"] },
        "position_side": {
          "type": ["string", "null"],
          "enum": ["LONG", "SHORT", null]
        },
        "position_amt": {
          "anyOf": [
            { "$ref": "#/$defs/decimal_string" },
            { "type": "null" }
          ]
        },
        "entry_price": {
          "anyOf": [
            { "$ref": "#/$defs/decimal_string" },
            { "type": "null" }
          ]
        },
        "mark_price": {
          "anyOf": [
            { "$ref": "#/$defs/decimal_string" },
            { "type": "null" }
          ]
        },
        "unrealized_profit": {
          "anyOf": [
            { "$ref": "#/$defs/decimal_string" },
            { "type": "null" }
          ]
        },
        "liquidation_price": {
          "anyOf": [
            { "$ref": "#/$defs/decimal_string" },
            { "type": "null" }
          ]
        }
      }
    },
    "borrow_validation_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coverage",
        "classic_margin_daily_interest_account_available",
        "chain_hit_tier",
        "chain_hit_source"
      ],
      "properties": {
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["probed", "skipped", "reason"],
          "properties": {
            "probed": { "type": "integer", "minimum": 0 },
            "skipped": { "type": "integer", "minimum": 0 },
            "reason": {
              "type": ["string", "null"],
              "enum": ["rate_limit_budget", null]
            }
          }
        },
        "classic_margin_daily_interest_account_available": { "type": "boolean" },
        "chain_hit_tier": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 4
        },
        "chain_hit_source": {
          "type": ["string", "null"],
          "enum": [
            "next_hourly",
            "rate_history",
            "cross_margin_tier",
            "vip0_reference",
            null
          ]
        }
      }
    }
  }
}
