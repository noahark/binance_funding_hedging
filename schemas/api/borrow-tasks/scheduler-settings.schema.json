{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.binance-funding-hedging/schemas/api/borrow-tasks/scheduler-settings.schema.json",
  "title": "Borrow Scheduler Settings",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "interval_seconds",
    "interval_us",
    "round_robin_cursor",
    "global_cooldown_until",
    "version",
    "updated_at"
  ],
  "properties": {
    "schema_version": {"const": "borrow-tasks/v1"},
    "interval_seconds": {"type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$"},
    "interval_us": {"type": "integer", "minimum": 100000},
    "round_robin_cursor": {"type": ["string", "null"]},
    "global_cooldown_until": {"type": ["string", "null"]},
    "version": {"type": "integer", "minimum": 1},
    "updated_at": {"type": "string"}
  }
}
