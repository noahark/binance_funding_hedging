{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.binance-funding-hedging/schemas/api/borrow-tasks/error.schema.json",
  "title": "Borrow API Error",
  "type": "object",
  "additionalProperties": false,
  "required": ["error", "detail"],
  "properties": {
    "error": {
      "enum": [
        "invalid_json",
        "invalid_field",
        "invalid_interval",
        "invalid_cursor",
        "invalid_limit",
        "unknown_task",
        "not_found",
        "method_not_allowed",
        "invalid_transition",
        "version_conflict",
        "body_too_large",
        "borrow_service_unavailable"
      ]
    },
    "detail": {"type": "string"}
  }
}
