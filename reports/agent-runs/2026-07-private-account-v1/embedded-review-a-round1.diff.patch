+    sample_dir = REPO_ROOT / "reports/api-samples/2026-07-private-account-v1"
+    leaks = []
+    for path in sample_dir.rglob("*.json"):
+        base = path.name
+        is_account = (
+            base in _ACCOUNT_LEVEL_SAMPLE_BASENAMES
+            or base.startswith("papi-v1-margin-maxBorrowable-")
+        )
