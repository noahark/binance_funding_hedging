#!/usr/bin/env python3
"""Run Claude-GLM through a real PTY while keeping runner evidence deterministic.

Claude Code switches ``-p`` and non-TTY stdout to its ``sdk-cli`` entrypoint.
The local GLM gateway has repeatedly returned API 529 on that route while the
same model succeeds through the interactive ``cli`` route.  This adapter gives
the existing absolute zsh wrapper a pseudo-terminal, supplies the immutable
prompt as the initial positional prompt, and exits only after the persisted
Claude transcript records a final ``cli`` assistant turn.

The adapter never expands or prints the ``claude-glm`` alias or environment.
Its stdout is the raw PTY byte stream plus a deterministic, non-secret session
marker; the auto runner remains the sole caller and receipt writer.
"""

from __future__ import annotations

import argparse
import errno
import fcntl
import json
import os
import pty
import select
import signal
import struct
import subprocess
import sys
import termios
import time
import uuid
from dataclasses import dataclass
from pathlib import Path
from typing import Sequence


POLICY_TOOLS = {
    "implementation-v1": ("Read", "Glob", "Grep", "Edit", "Write"),
    "review-readonly-v1": ("Read", "Glob", "Grep"),
}


@dataclass(frozen=True)
class TranscriptOutcome:
    success: bool
    reason: str
    entrypoint: str | None
    model: str | None
    path: Path


def _text_blocks(message: dict) -> list[str]:
    content = message.get("content")
    if isinstance(content, str):
        return [content]
    if not isinstance(content, list):
        return []
    return [
        block.get("text", "")
        for block in content
        if isinstance(block, dict)
        and block.get("type") == "text"
        and isinstance(block.get("text"), str)
    ]


def inspect_transcript(transcript_root: Path, session_id: str) -> TranscriptOutcome | None:
    """Return only a terminal assistant outcome for the requested UUID."""
    paths = sorted(transcript_root.glob("*/" + session_id + ".jsonl"))
    if not paths:
        return None
    path = paths[0]
    try:
        lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    except OSError:
        return None
    for raw in reversed(lines):
        try:
            item = json.loads(raw)
        except json.JSONDecodeError:
            continue
        if item.get("type") != "assistant" or not isinstance(item.get("message"), dict):
            continue
        message = item["message"]
        model = message.get("model")
        entrypoint = item.get("entrypoint")
        texts = _text_blocks(message)
        if model == "<synthetic>" and texts:
            return TranscriptOutcome(False, "synthetic_provider_error", entrypoint, model, path)
        if message.get("stop_reason") == "end_turn" and texts and model:
            if entrypoint != "cli":
                return TranscriptOutcome(
                    False, "unexpected_entrypoint:" + str(entrypoint), entrypoint, model, path
                )
            return TranscriptOutcome(True, "cli_end_turn", entrypoint, model, path)
    return None


def load_tool_policy(path: Path, *, policy_id: str, cwd: Path) -> dict:
    """Load the runner-generated Claude settings file and fail closed on drift."""
    resolved = path.resolve()
    try:
        resolved.relative_to(cwd.resolve())
    except ValueError as exc:
        raise ValueError("tool policy must stay inside the repository worktree") from exc
    try:
        policy = json.loads(resolved.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        raise ValueError("tool policy is missing or invalid JSON") from exc
    if not isinstance(policy, dict) or set(policy) != {"permissions"}:
        raise ValueError("tool policy must contain only permissions")
    permissions = policy.get("permissions")
    if not isinstance(permissions, dict) or set(permissions) != {"defaultMode", "allow", "deny"}:
        raise ValueError("tool policy permissions shape is invalid")
    if permissions.get("defaultMode") != "dontAsk":
        raise ValueError("tool policy defaultMode must be dontAsk")
    for key in ("allow", "deny"):
        rules = permissions.get(key)
        if (
            not isinstance(rules, list)
            or len(rules) != len(set(rules))
            or any(not isinstance(rule, str) or not rule for rule in rules)
        ):
            raise ValueError("tool policy permissions.%s must be a unique string list" % key)
    allow = permissions["allow"]
    if any(rule == "Bash" or rule.startswith("Bash(") for rule in allow):
        raise ValueError("tool policy must not allow Bash")
    if "Bash" not in permissions["deny"]:
        raise ValueError("tool policy must explicitly deny Bash")
    write_rules = [
        rule for rule in allow
        if rule.startswith("Edit(") or rule.startswith("Write(")
    ]
    if policy_id == "implementation-v1":
        if not any(rule.startswith("Edit(") for rule in write_rules):
            raise ValueError("implementation policy requires bounded Edit rules")
        if not any(rule.startswith("Write(") for rule in write_rules):
            raise ValueError("implementation policy requires bounded Write rules")
    elif write_rules:
        raise ValueError("read-only policy must not allow Edit or Write")
    return policy


def policy_cli_args(path: Path, *, policy_id: str, cwd: Path) -> list[str]:
    """Return the complete frozen Claude CLI permission surface for a policy."""
    load_tool_policy(path, policy_id=policy_id, cwd=cwd)
    return [
        "--safe-mode",
        "--permission-mode", "dontAsk",
        "--tools", ",".join(POLICY_TOOLS[policy_id]),
        "--settings", str(path.resolve()),
        "--strict-mcp-config",
        "--mcp-config", '{"mcpServers":{}}',
        "--disable-slash-commands",
    ]


def _terminate_group(proc: subprocess.Popen[bytes], grace: float = 2.0) -> None:
    if proc.poll() is not None:
        return
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except ProcessLookupError:
        return
    try:
        proc.wait(timeout=grace)
        return
    except subprocess.TimeoutExpired:
        pass
    try:
        os.killpg(proc.pid, signal.SIGKILL)
    except ProcessLookupError:
        return
    proc.wait(timeout=grace)


def _drain(master_fd: int, captured: bytearray, timeout: float) -> bool:
    """Drain one PTY chunk. Return False after slave closure."""
    ready, _, _ = select.select([master_fd], [], [], timeout)
    if not ready:
        return True
    try:
        chunk = os.read(master_fd, 65536)
    except OSError as exc:
        if exc.errno == errno.EIO:
            return False
        raise
    if not chunk:
        return False
    captured.extend(chunk)
    return True


def run_pty_session(
    command: Sequence[str],
    *,
    transcript_root: Path,
    session_id: str,
    timeout_seconds: float,
    env: dict[str, str] | None = None,
    cwd: Path | None = None,
) -> tuple[bytes, TranscriptOutcome | None, int | None, bool]:
    """Run ``command`` in a PTY and stop after a final persisted turn."""
    master_fd, slave_fd = pty.openpty()
    captured = bytearray()
    proc: subprocess.Popen[bytes] | None = None
    timed_out = False
    outcome: TranscriptOutcome | None = None
    try:
        # Give the TUI a stable size so it does not block on terminal probing.
        fcntl.ioctl(slave_fd, termios.TIOCSWINSZ, struct.pack("HHHH", 40, 160, 0, 0))
        child_env = dict(os.environ if env is None else env)
        child_env.setdefault("TERM", "xterm-256color")
        proc = subprocess.Popen(
            list(command),
            cwd=str(cwd) if cwd is not None else None,
            env=child_env,
            stdin=slave_fd,
            stdout=slave_fd,
            stderr=slave_fd,
            start_new_session=True,
            close_fds=True,
        )
        os.close(slave_fd)
        slave_fd = -1
        deadline = time.monotonic() + timeout_seconds
        outcome_seen_at: float | None = None
        exit_sent = False
        while True:
            stream_open = _drain(master_fd, captured, 0.2)
            latest = inspect_transcript(transcript_root, session_id)
            if latest is not None:
                outcome = latest
                if outcome_seen_at is None:
                    outcome_seen_at = time.monotonic()
            now = time.monotonic()
            # Allow split thinking/text records and terminal rendering to flush.
            if outcome_seen_at is not None and now - outcome_seen_at >= 1.0 and not exit_sent:
                try:
                    os.write(master_fd, b"/exit\r")
                except OSError:
                    pass
                exit_sent = True
            if exit_sent and now - outcome_seen_at >= 6.0:
                break
            if proc.poll() is not None or not stream_open:
                break
            if now >= deadline:
                timed_out = True
                break
        _terminate_group(proc)
        for _ in range(100):
            if not _drain(master_fd, captured, 0.01):
                break
        return bytes(captured), outcome, proc.returncode, timed_out
    finally:
        if proc is not None:
            _terminate_group(proc)
        if slave_fd >= 0:
            os.close(slave_fd)
        os.close(master_fd)


def _parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(add_help=True)
    parser.add_argument("--model", required=True)
    parser.add_argument("--policy", choices=tuple(POLICY_TOOLS))
    parser.add_argument("--tool-policy-file")
    parser.add_argument("--dangerously-skip-permissions", action="store_true")
    parser.add_argument("--prompt-file", required=True)
    parser.add_argument("--timeout-seconds", type=int, default=2400)
    return parser


def main(argv: Sequence[str] | None = None) -> int:
    args = _parser().parse_args(argv)
    if args.timeout_seconds <= 0:
        raise SystemExit("--timeout-seconds must be positive")
    prompt_path = Path(args.prompt_file).resolve()
    prompt = prompt_path.read_text(encoding="utf-8")
    session_id = str(uuid.uuid4())
    wrapper = Path(__file__).resolve().with_name("claude-glm-wrapper")
    command = [str(wrapper), "--model", args.model]
    if args.dangerously_skip_permissions:
        if args.policy or args.tool_policy_file:
            raise SystemExit("yolo mode cannot be combined with a bounded tool policy")
        command.append("--dangerously-skip-permissions")
    else:
        if not args.policy or not args.tool_policy_file:
            raise SystemExit("--policy and --tool-policy-file are required outside yolo mode")
        policy_path = Path(args.tool_policy_file).resolve()
        try:
            command.extend(
                policy_cli_args(policy_path, policy_id=args.policy, cwd=Path.cwd())
            )
        except ValueError as exc:
            raise SystemExit("claude-glm PTY adapter: " + str(exc)) from exc
    command.extend(["--session-id", session_id, prompt])
    transcript_root = Path.home() / ".claude" / "projects"
    raw, outcome, child_rc, timed_out = run_pty_session(
        command,
        transcript_root=transcript_root,
        session_id=session_id,
        timeout_seconds=float(args.timeout_seconds),
        cwd=Path.cwd(),
    )
    sys.stdout.buffer.write(raw)
    sys.stdout.buffer.write(
        ("\nHARNESS_PTY_SESSION_ID=" + session_id + "\n").encode("ascii")
    )
    if timed_out:
        sys.stderr.write("claude-glm PTY adapter: timed out before a final cli turn\n")
        return 124
    if outcome is None:
        sys.stderr.write(
            "claude-glm PTY adapter: process ended without a final persisted assistant turn"
            + (" (child=" + str(child_rc) + ")" if child_rc is not None else "")
            + "\n"
        )
        return child_rc if child_rc not in (None, 0) else 1
    if outcome.model != args.model:
        sys.stderr.write(
            "claude-glm PTY adapter: persisted model mismatch; expected "
            + args.model + " got " + str(outcome.model) + "\n"
        )
        return 1
    sys.stdout.buffer.write(
        (
            "HARNESS_PTY_OUTCOME=" + outcome.reason
            + " entrypoint=" + str(outcome.entrypoint)
            + " model=" + str(outcome.model) + "\n"
        ).encode("utf-8")
    )
    return 0 if outcome.success else 1


if __name__ == "__main__":
    raise SystemExit(main())
