#!/usr/bin/env python3
"""Independent task-branch mode: integrate two task branches and prepare review-2.

Deterministic integrator (no model calls). Runs with cwd = the integration
worktree. It ingests each task worktree's uncommitted checkpoint.json + review-1
artifacts, enforces anti-stale-tip, merges the disjoint task branches atomically
(sequential --no-ff, rollback via `git reset --hard`), proves the rebind, reruns
full tests, and writes the single top-level status.json. See DRAFT-2 rev c2 §10.
"""

from __future__ import annotations

import argparse
import hashlib
import json
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from _itbm import (  # noqa: E402
    ItbmError,
    canonical_fingerprint,
    changed_files,
    git,
    hits_protected_path,
    product_rebind_hash,
    rev_parse,
    status_rel,
)


def sha256_file(path: Path) -> str:
    return hashlib.sha256(path.read_bytes()).hexdigest()


def read_json(path: Path) -> dict:
    if not path.exists():
        raise ItbmError(f"missing ingest artifact: {path}")
    return json.loads(path.read_text())


def ingest_task(repo: Path, stage_id: str, task: dict, worktree: Path) -> dict:
    task_id = str(task["id"])
    branch = task["branch"]
    # verify the worktree is checked out on the expected branch
    head_branch = str(git(["rev-parse", "--abbrev-ref", "HEAD"], cwd=worktree)).strip()
    if head_branch != branch:
        raise ItbmError(f"{worktree} is on {head_branch!r}, expected task branch {branch!r}")
    ev = worktree / "reports" / "agent-runs" / stage_id / "evidence" / task_id
    checkpoint = read_json(ev / "checkpoint.json")
    verdict = read_json(ev / "review-1.verdict.json")
    attempts = read_json(ev / "review-1.attempts.json") if (ev / "review-1.attempts.json").exists() else {}
    provenance = {
        name: sha256_file(ev / name)
        for name in ("checkpoint.json", "review-1.verdict.json", "30-review-1.md")
        if (ev / name).exists()
    }
    return {
        "task_id": task_id,
        "branch": branch,
        "evidence_dir": ev,
        "checkpoint": checkpoint,
        "verdict": verdict,
        "attempts": attempts,
        "provenance": provenance,
    }


def assert_anti_stale_tip(repo: Path, base: str, stage_id: str, ing: dict) -> None:
    branch = ing["branch"]
    cp = ing["checkpoint"]
    tip = rev_parse(branch, cwd=repo)
    if tip != cp["head_sha"]:
        raise ItbmError(f"anti-stale-tip: {branch} tip {tip[:12]} != checkpoint.head_sha {cp['head_sha'][:12]}")
    recomputed = canonical_fingerprint(repo, base, tip, stage_id)
    if recomputed != cp["task_diff_fingerprint"]:
        raise ItbmError(f"task_diff_fingerprint mismatch for {branch}: recomputed {recomputed} != checkpoint {cp['task_diff_fingerprint']}")
    if ing["verdict"].get("diff_fingerprint") != cp["task_diff_fingerprint"]:
        raise ItbmError(f"review-1 verdict diff_fingerprint != checkpoint for {branch}")


def product_changed(repo: Path, base: str, branch: str) -> set[str]:
    return {p for p in changed_files(repo, base, branch) if not p.startswith("reports/")}


def main() -> int:
    parser = argparse.ArgumentParser(description="Integrate task branches and prepare review-2")
    parser.add_argument("stage_id")
    parser.add_argument("--base-sha", required=True)
    parser.add_argument("--integration-branch", required=True)
    parser.add_argument("--backend-worktree", required=True)
    parser.add_argument("--frontend-worktree", required=True)
    parser.add_argument("--human-decision", required=True, choices=["proceed_to_review_2"])
    parser.add_argument("--rationale", required=True)
    parser.add_argument("--no-validator", action="store_true")
    args = parser.parse_args()

    repo = Path(git(["rev-parse", "--show-toplevel"], cwd=Path.cwd()).strip())
    stage_id = args.stage_id
    base = rev_parse(args.base_sha, cwd=repo)
    t0 = rev_parse(args.integration_branch, cwd=repo)

    try:
        frozen = json.loads(str(git(["show", f"{base}:{status_rel(stage_id)}"], cwd=repo)))
        tasks = frozen.get("tasks", [])
        if len(tasks) != 2:
            raise ItbmError("integration expects exactly two tasks")
        worktrees = {"backend": Path(args.backend_worktree).resolve(), "frontend": Path(args.frontend_worktree).resolve()}

        # (1) ingest + (2) anti-stale-tip + (3) review-1 ACCEPT / attempts
        ingested = []
        for task in tasks:
            wt = worktrees.get(str(task["id"]))
            if wt is None:
                raise ItbmError(f"no --{task['id']}-worktree provided")
            ing = ingest_task(repo, stage_id, task, wt)
            assert_anti_stale_tip(repo, base, stage_id, ing)
            if ing["verdict"].get("verdict") != "ACCEPT":
                raise ItbmError(f"task {ing['task_id']} review-1 verdict is not ACCEPT")
            for model, n in (ing["attempts"].get("invalid_json_attempts") or {}).items():
                if int(n) > 2:
                    raise ItbmError(f"task {ing['task_id']} model {model} invalid_json_attempts {n} > 2")
            ingested.append(ing)

        # (4) immutable guard on merged set + (5) ancestry + (6) product intersection empty
        prod_sets = {}
        for ing in ingested:
            for p in changed_files(repo, base, ing["branch"]):
                if hits_protected_path(p):
                    raise ItbmError(f"immutable-guard: {ing['branch']} touches protected path {p}")
            git(["merge-base", "--is-ancestor", base, ing["branch"]], cwd=repo)
            prod_sets[ing["task_id"]] = product_changed(repo, base, ing["branch"])
        inter = prod_sets[ingested[0]["task_id"]] & prod_sets[ingested[1]["task_id"]]
        if inter:
            raise ItbmError(f"product changed-file intersection is non-empty: {sorted(inter)}")

        # (7) atomic integration
        git(["checkout", args.integration_branch], cwd=repo)
        merge_order = [ingested[0]["branch"], ingested[1]["branch"]]
        for branch in merge_order:
            git(["merge", "--no-ff", "-m", f"integrate {branch}", branch], cwd=repo)
        # ingest commit M3: copy sidecars + review-1 artifacts into integration evidence
        for ing in ingested:
            dst = repo / "reports" / "agent-runs" / stage_id / "evidence" / ing["task_id"]
            dst.mkdir(parents=True, exist_ok=True)
            for name in ("checkpoint.json", "review-1.verdict.json", "review-1.attempts.json", "30-review-1.md", "60-test-output.txt"):
                src = ing["evidence_dir"] / name
                if src.exists():
                    (dst / name).write_text(src.read_text())
        git(["add", "-A"], cwd=repo)
        git(["commit", "-m", f"[integration:{stage_id}] ingest review-1 evidence"], cwd=repo)
        merge_head = rev_parse("HEAD", cwd=repo)

        # (7a) rebind assertion per task (merge_head now exists)
        for ing in ingested:
            integ = product_rebind_hash(repo, base, merge_head, ing["checkpoint"]["product_paths"])
            if integ != ing["checkpoint"]["product_rebind_hash"]:
                raise ItbmError(f"rebind mismatch for {ing['task_id']}: integration {integ} != task {ing['checkpoint']['product_rebind_hash']}")

        # (7b) full stage tests
        stage_cmd = frozen.get("stage_test_command")
        if stage_cmd:
            proc = subprocess.run(stage_cmd, shell=True, cwd=str(repo), stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
            (repo / "reports" / "agent-runs" / stage_id / "60-test-output.txt").write_text(proc.stdout)
            if proc.returncode != 0:
                raise ItbmError(f"full stage tests failed:\n{proc.stdout[-2000:]}")

        integration_fp = canonical_fingerprint(repo, base, merge_head, stage_id)

        # (8) write single top-level status.json
        status = dict(frozen)
        status["status"] = "review_2"
        status["base_sha"] = base
        status["head_sha"] = merge_head
        status["diff_fingerprint"] = integration_fp
        status["integration_diff_fingerprint"] = integration_fp
        status["merge_order"] = merge_order
        for task in status["tasks"]:
            ing = next(i for i in ingested if i["task_id"] == str(task["id"]))
            task["base_sha"] = base
            task["head_sha"] = ing["checkpoint"]["head_sha"]
            task["task_diff_fingerprint"] = ing["checkpoint"]["task_diff_fingerprint"]
            task["review_1"] = {"verdict": "ACCEPT", "diff_fingerprint": ing["checkpoint"]["task_diff_fingerprint"]}
        from datetime import datetime
        status["human_decision"] = {
            "decided_by": "human",
            "decision": args.human_decision,
            "rationale": args.rationale,
            "reviewed_task_fingerprints": {i["task_id"]: i["checkpoint"]["task_diff_fingerprint"] for i in ingested},
            "timestamp": datetime.now().astimezone().isoformat(),
        }
        (repo / status_rel(stage_id)).write_text(json.dumps(status, indent=2) + "\n")
        git(["add", "-A"], cwd=repo)
        git(["commit", "-m", f"[integration:{stage_id}] status review_2 + human_decision"], cwd=repo)

        if not args.no_validator and (repo / "scripts" / "validate-stage.py").exists():
            subprocess.run([sys.executable, "scripts/validate-stage.py", stage_id, "--phase", "pre-review"], cwd=str(repo), check=False)

        print(f"PREPARE-REVIEW-2 OK integration_head={merge_head[:12]}")
        print(f"integration_diff_fingerprint={integration_fp}")
        return 0
    except Exception as exc:  # noqa: BLE001 — any failure must roll back atomically
        try:
            git(["merge", "--abort"], cwd=repo, text=False)
        except ItbmError:
            pass
        git(["checkout", args.integration_branch], cwd=repo, text=False)
        git(["reset", "--hard", t0], cwd=repo, text=False)
        print("PREPARE-REVIEW-2 BLOCKED (rolled back to T0)")
        print(f"- {exc}")
        return 1


if __name__ == "__main__":
    sys.exit(main())
