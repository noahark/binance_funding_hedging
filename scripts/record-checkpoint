#!/usr/bin/env python3
"""Independent task-branch mode: anchor one task branch to review-1.

Deterministic recorder (no model calls). Runs from a TRUSTED checkout (the
integration/main worktree) and operates on the task branch via git refs; it only
reads (status/diff) and stages/commits inside the task worktree, and never runs
the task worktree's own scripts/ copy. See
reports/agent-runs/2026-07-harness-flow-optimization-v1/10-independent-task-branch-mode-draft.md
§9 (DRAFT-2 rev c2).
"""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from _itbm import (  # noqa: E402
    ItbmError,
    canonical_fingerprint,
    changed_files,
    git,
    hits_protected_path,
    path_in_scope,
    product_rebind_hash,
    rev_parse,
    status_rel,
    worktree_changed_files,
)


def load_frozen_status(repo: Path, base_sha: str, stage_id: str) -> dict:
    """Read the frozen top-level status.json at base (F4: not the worktree copy)."""
    blob = str(git(["show", f"{base_sha}:{status_rel(stage_id)}"], cwd=repo))
    return json.loads(blob)


def find_task(status: dict, task_id: str) -> dict:
    for task in status.get("tasks", []):
        if str(task.get("id")) == task_id:
            return task
    raise ItbmError(f"task {task_id!r} not found in frozen status.json tasks[]")


def assert_ancestry(repo: Path, base_sha: str, branch: str) -> None:
    # base is an ancestor of the branch tip
    res = git(["merge-base", "--is-ancestor", base_sha, branch], cwd=repo, text=False)  # noqa: F841
    # no sibling/main merge: the branch first-parent history from base must be linear
    commits = str(git(["rev-list", "--merges", f"{base_sha}..{branch}"], cwd=repo)).strip()
    if commits:
        raise ItbmError(f"task branch {branch} contains merge commits (sibling/main merge forbidden)")


def run_single_owner(repo: Path, args, stage_id: str) -> int:
    """Single-owner: one worktree, record-checkpoint writes top-level status.json."""
    worktree = Path(args.task_worktree).resolve()
    base = rev_parse(args.base_sha, cwd=repo)
    pending = worktree_changed_files(worktree)
    for path in pending:
        if hits_protected_path(path):
            raise ItbmError(f"single-owner change touches protected Harness path: {path}")
    git(["add", "-A"], cwd=worktree)
    git(["commit", "-m", f"[checkpoint:single-owner] {stage_id}"], cwd=worktree)
    head = rev_parse(args.branch, cwd=repo)
    fp = canonical_fingerprint(repo, base, head, stage_id)
    print(f"single-owner checkpoint head={head[:12]} fingerprint={fp}")
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(description="Anchor one task branch to review-1")
    parser.add_argument("stage_id")
    parser.add_argument("--task", required=False)
    parser.add_argument("--branch", required=True)
    parser.add_argument("--task-worktree", required=True)
    parser.add_argument("--base-sha", required=True)
    parser.add_argument("--single-owner", action="store_true")
    args = parser.parse_args()

    repo = Path(git(["rev-parse", "--show-toplevel"], cwd=Path.cwd()).strip())
    stage_id = args.stage_id

    try:
        if args.single_owner:
            return run_single_owner(repo, args, stage_id)

        if not args.task:
            raise ItbmError("--task is required for double-owner checkpoint")
        worktree = Path(args.task_worktree).resolve()
        base = rev_parse(args.base_sha, cwd=repo)
        task_id = args.task
        evidence_prefix = f"reports/agent-runs/{stage_id}/evidence/{task_id}/"

        # (1) ancestry / no sibling-merge
        assert_ancestry(repo, base, args.branch)

        # (2) frozen policy (F4: git show base, not the worktree copy)
        status = load_frozen_status(repo, base, stage_id)
        task = find_task(status, task_id)
        scope = task.get("allowed_scope", {})
        product_paths = scope.get("product_paths") or []
        test_command = scope.get("test_command")
        allow_harness = bool(scope.get("allow_harness_change", False))
        if not product_paths:
            raise ItbmError(f"task {task_id} has no allowed_scope.product_paths")

        # (3) pre-commit worktree candidate validation
        pending = worktree_changed_files(worktree)
        if not pending:
            raise ItbmError("no uncommitted candidate changes in the task worktree")
        for path in pending:
            if hits_protected_path(path):
                if not allow_harness:
                    raise ItbmError(
                        f"immutable-guard: change touches protected Harness path {path} "
                        f"(allow_harness_change is false for product tasks)"
                    )
            elif not path_in_scope(path, product_paths, evidence_prefix):
                raise ItbmError(f"out-of-scope change: {path} not in product_paths or {evidence_prefix}")

        # (4) stage + commit C_e (= task_head)
        git(["add", "-A"], cwd=worktree)
        git(["commit", "-m", f"[checkpoint:{task_id}] {stage_id}"], cwd=worktree)

        # (5) post-commit completeness: worktree must be fully clean (codex R1)
        leftover = worktree_changed_files(worktree)
        if leftover:
            raise ItbmError(
                "post-commit worktree not clean; C_e does not fully capture the candidate: "
                + ", ".join(leftover)
            )

        head = rev_parse(args.branch, cwd=repo)

        # (6) recompute guard/scope on committed base..C_e (defense in depth) + fingerprints
        for path in changed_files(repo, base, head):
            if hits_protected_path(path) and not allow_harness:
                raise ItbmError(f"immutable-guard (committed): protected path {path}")
            if not hits_protected_path(path) and not path_in_scope(path, product_paths, evidence_prefix):
                raise ItbmError(f"out-of-scope (committed): {path}")
        task_fp = canonical_fingerprint(repo, base, head, stage_id)
        rebind = product_rebind_hash(repo, base, head, product_paths)

        # (7) run frozen test command against C_e (worktree == C_e) -> task-local evidence
        ev_dir = worktree / "reports" / "agent-runs" / stage_id / "evidence" / task_id
        ev_dir.mkdir(parents=True, exist_ok=True)
        test_out = ev_dir / "60-test-output.txt"
        test_status = "skipped"
        if test_command:
            import subprocess

            proc = subprocess.run(
                test_command, shell=True, cwd=str(worktree),
                stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True,
            )
            test_out.write_text(proc.stdout)
            test_status = "pass" if proc.returncode == 0 else "fail"
            if proc.returncode != 0:
                raise ItbmError(f"frozen test_command failed (see {test_out}):\n{proc.stdout[-2000:]}")

        # (8) write uncommitted sidecar checkpoint.json (A2: never committed to task branch)
        checkpoint = {
            "task_id": task_id,
            "base_sha": base,
            "head_sha": head,
            "task_diff_fingerprint": task_fp,
            "product_rebind_hash": rebind,
            "product_paths": product_paths,
            "test_status": test_status,
        }
        (ev_dir / "checkpoint.json").write_text(json.dumps(checkpoint, indent=2) + "\n")

        print(f"CHECKPOINT OK task={task_id} head={head[:12]}")
        print(f"task_diff_fingerprint={task_fp}")
        print(f"product_rebind_hash={rebind}")
        return 0
    except ItbmError as exc:
        print("RECORD-CHECKPOINT BLOCKED")
        print(f"- {exc}")
        return 1


if __name__ == "__main__":
    sys.exit(main())
